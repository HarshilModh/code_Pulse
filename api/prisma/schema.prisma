generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id          String   @id
  email       String   @unique
  plan        String   @default("free")
  repoLimit   Int      @default(3)
  clerkId     String?  @unique
  githubLogin String?
  createdAt   DateTime @default(now())
  repos       Repo[]
}

model Repo {
  id             String         @id @default(cuid())
  githubRepoId   Int
  owner          String
  name           String
  installationId Int?
  source         String         @default("github_app")
  defaultBranch  String         @default("main")
  isPublicDemo   Boolean        @default(false)
  lastAnalyzedAt DateTime?
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  createdAt      DateTime       @default(now())
  snapshots      Snapshot[]
  fileAnalyses   FileAnalysis[]
  settings       RepoSettings?    
  findings       Finding[]
  @@unique([userId, githubRepoId])
}

model Snapshot {
  id           String         @id @default(cuid())
  repoId       String
  repo         Repo           @relation(fields: [repoId], references: [id], onDelete: Cascade)
  commitSha    String
  healthScore  Float
  complexity   Float
  vulnCount    Int
  deadCode     Float
  coverage     Float
  driftScore   Float
  createdAt    DateTime       @default(now())
  fileAnalyses FileAnalysis[]
  insight      Insight?
  

  @@index([repoId, createdAt])
}

model FileAnalysis {
  id         String                       @id @default(cuid())
  repoId     String
  repo       Repo                         @relation(fields: [repoId], references: [id], onDelete: Cascade)
  snapshotId String?
  snapshot   Snapshot?                    @relation(fields: [snapshotId], references: [id])
  filePath   String
  complexity Float                        @default(0)
  isDead     Boolean                      @default(false)
  driftScore Float?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())
  functionMetrics FunctionMetric[]

  @@unique([repoId, filePath])
  @@index([repoId])
}

model DigestLog {
  id      String   @id @default(cuid())
  repoId  String
  sentAt  DateTime @default(now())
  summary Json
}

model Insight {
    id           String   @id @default(cuid())                                                                                       
    snapshotId   String   @unique
    snapshot     Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
    topRisks     Json                                                                                                                
    improvements Json
    nextAction   String                                                                                                              
    model        String
    tokensIn     Int                                                                                                                 
    tokensOut    Int
    createdAt    DateTime @default(now())                                                                                            
  }               

  model ChatSession {                                                                                                                
    id        String        @id @default(cuid())
    repoId    String                                                                                                                 
    userId    String
    mode      String        @default("chat")
    createdAt DateTime      @default(now())                                                                                          
    messages  ChatMessage[]
                                                                                                                                     
    @@index([repoId, userId])
  }

  model ChatMessage {
    id        String      @id @default(cuid())
    sessionId String                                                                                                                 
    session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    role      String                                                                                                                 
    content   String      @db.Text                                                                                                   
    toolCalls Json?
    citations Json?                                                                                                                  
    tokensIn  Int?
    tokensOut Int?
    persona   String?
    createdAt DateTime    @default(now())
  }                                                                                                                                  
   
model FunctionMetric{
    id             String       @id @default(cuid())                                                                                                                                    
    fileAnalysisId String                                                                                                                                                               
    fileAnalysis   FileAnalysis @relation(fields: [fileAnalysisId], references: [id], onDelete: Cascade)                                                                                
    name           String                                                                                                                                                               
    startLine      Int
    endLine        Int                                                                                                                                                                  
    cyclomatic     Float
                                                                                                                                                                                        
    @@index([fileAnalysisId])
}

model RepoSettings{
   repoId           String   @id
   repo             Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
   driftThreshold   Float    @default(0.72)                                                                                                                                            
   digestCadence    String   @default("weekly")
   digestRecipients String[] @default([])                                                                                                                                              
   alertRules       Json     @default("[]")                                                                                                                                            
   updatedAt        DateTime @updatedAt
}
model Finding {
    id            String           @id @default(cuid())                                                                                                                                 
    repoId        String                                    
    repo          Repo             @relation(fields: [repoId], references: [id], onDelete: Cascade)
    type          String                                                                                                                                                                
    severity      String
    filePath      String?                                                                                                                                                               
    line          Int?                                      
    title         String
    body          String           @db.Text
    status        String           @default("open")                                                                                                                                     
    snoozedUntil  DateTime?
    dismissReason String?                                                                                                                                                               
    assigneeId    String?                                                                                                                                                               
    createdAt     DateTime         @default(now())
    updatedAt     DateTime         @updatedAt                                                                                                                                           
    comments      FindingComment[]                          

    @@index([repoId, status])                                                                                                                                                           
    @@index([repoId, type])
    @@unique([repoId, type, filePath])   // prevents duplicate findings on re-runs                                                             
   
  }                                                                                                                                                                                     
                                                            
  model FindingComment {
    id        String   @id @default(cuid())
    findingId String
    finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
    userId    String                                                                                                                                                                    
    body      String   @db.Text
    createdAt DateTime @default(now())                                                                                                                                                  
  }            
  model ApiKey {
    id        String   @id @default(cuid())
    userId    String
    name      String
    key      String   @unique //SHA-256 hash of the actual key
    prefix   String   // First 10 chars of the actual key, for display purposes
    lastUsedAt DateTime?
    createdAt DateTime @default(now())

    @@index([userId])
  }