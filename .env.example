# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=        # Path to your .pem file
GITHUB_WEBHOOK_SECRET=          # Random string set in GitHub App settings
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Neon PostgreSQL — both required
DATABASE_URL=                   # Pooled connection string — runtime queries
DIRECT_URL=                     # Direct connection string — migrations only
# Append to both: ?connect_timeout=30&pool_timeout=30

# Redis
REDIS_URL=                      # From Render Redis dashboard

# OpenAI
OPENAI_API_KEY=                 # For text-embedding-3-small

# Clerk (dashboard auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=                   # localhost:3001 in dev, Vercel URL in prod
